  "regexRecognizers": [
    {
      "type": "SSN",
      "pattern": "\\b(?!000|666|9\\d{2})(\\d{3})-(?!00)(\\d{2})-(?!0000)(\\d{4})\\b",
      "validator": "ssn_format"
    },
    {
      "type": "CREDIT_CARD",
      "pattern": "\\b(?:\\d[ -]?){13,19}\\b",
      "validator": "luhn"
    },
    {
      "type": "MRN",
      "pattern": "\\b(?:MRN|Medical Record(?: Number)?)[:#\\s]*([A-Z0-9-]{4,12})\\b",
      "validator": "none",
      "captureGroup": 1
    }
  ],
  "dobCueWords": [
    "dob",
